    <sql id="invoiceColumns">
        id, region, scac, inv_no, inv_date, payment_terms, cur, inv_amount, tt_charge,
        pickup_date, pickup_time, pod_date, pod_time, pod_name,
        gross_weight, gw_qualifier, gw_unit, bill_weight, bw_qualifier, bw_unit, bol,
        status, import_batch, create_user, create_time, update_user, update_time
    </sql>

    <sql id="whereList">
        <where>
            <if test="params.region != null and params.region != ''">
                AND i.region = #{params.region}
            </if>
            <if test="params.scac != null and params.scac != ''">
                AND i.scac = #{params.scac}
            </if>
            <if test="params.invNo != null and params.invNo != ''">
                AND i.inv_no LIKE CONCAT('%', #{params.invNo}, '%')
            </if>
            <if test="params.bol != null and params.bol != ''">
                AND i.bol LIKE CONCAT('%', #{params.bol}, '%')
            </if>
            <if test="params.dateFrom != null and params.dateFrom != ''">
                AND i.inv_date &gt;= #{params.dateFrom}
            </if>
            <if test="params.dateTo != null and params.dateTo != ''">
                AND i.inv_date &lt;= #{params.dateTo}
            </if>
            <if test="params.status != null">
                AND i.status = #{params.status}
            </if>
        </where>
    </sql>

    <insert id="insert" parameterType="com.boot.security.server.model.EDI210Invoice"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO edi_210_invoice
        (region, scac, inv_no, inv_date, payment_terms, cur, inv_amount, tt_charge,
         pickup_date, pickup_time, pod_date, pod_time, pod_name,
         gross_weight, gw_qualifier, gw_unit, bill_weight, bw_qualifier, bw_unit, bol,
         status, import_batch, create_user, create_time)
        VALUES
        (#{region}, #{scac}, #{invNo}, #{invDate}, #{paymentTerms}, #{cur}, #{invAmount}, #{ttCharge},
         #{pickupDate}, #{pickupTime}, #{podDate}, #{podTime}, #{podName},
         #{grossWeight}, #{gwQualifier}, #{gwUnit}, #{billWeight}, #{bwQualifier}, #{bwUnit}, #{bol},
         #{status}, #{importBatch}, #{createUser}, NOW())
    </insert>

