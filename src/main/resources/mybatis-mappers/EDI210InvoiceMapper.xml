            update_time = NOW(),
        </set>
        WHERE id = #{id}
    </update>

    <select id="count" resultType="int">
        SELECT COUNT(*) FROM edi_210_invoice i
        <include refid="whereList"/>
    </select>

    <select id="list" resultMap="ListResultMap">
        SELECT
            i.id, i.region, i.scac, i.inv_no, i.inv_date, i.bol, i.cur, i.inv_amount,
            i.status,
            DATE_FORMAT(i.create_time, '%Y-%m-%d %H:%i:%s') AS create_time,
            bt.name1 AS bill_to_name,
            sh.name1 AS shipper_name,
            cn.name1 AS consignee_name,
            (SELECT COUNT(*) FROM edi_210_charge c WHERE c.invoice_id = i.id) AS charge_count
        FROM edi_210_invoice i
        LEFT JOIN edi_210_party bt ON bt.invoice_id = i.id AND bt.party_role = 'BILL_TO'
        LEFT JOIN edi_210_party sh ON sh.invoice_id = i.id AND sh.party_role = 'SHIPPER'
        LEFT JOIN edi_210_party cn ON cn.invoice_id = i.id AND cn.party_role = 'CONSIGNEE'
        <include refid="whereList"/>
        ORDER BY i.id DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="exportFlat" resultMap="ExcelRowResultMap">
        SELECT
            i.region,
            -- Bill-To
            bt.name1 AS bt_name1, bt.name2 AS bt_name2,
            bt.address1 AS bt_address1, bt.address2 AS bt_address2,
            bt.city AS bt_city, bt.country AS bt_country,
            bt.postal_code AS bt_postal_code, bt.state_province AS bt_state_province,
            bt.account AS bt_account, bt.location AS bt_location,
            -- Bill-From
            bf.name1 AS bf_name1, bf.address1 AS bf_address1,
            bf.city AS bf_city, bf.postal_code AS bf_postal_code, bf.country AS bf_country,
            -- Shipper
            sh.name1 AS sh_name1, sh.name2 AS sh_name2,
            sh.address1 AS sh_address1, sh.address2 AS sh_address2,
            sh.city AS sh_city, sh.country AS sh_country,
            sh.postal_code AS sh_postal_code, sh.state_province AS sh_state_province,
            sh.account AS sh_account, sh.location AS sh_location,
            -- Consignee
            cn.name1 AS cn_name1, cn.name2 AS cn_name2,
            cn.address1 AS cn_address1, cn.address2 AS cn_address2,
            cn.city AS cn_city, cn.country AS cn_country,
            cn.postal_code AS cn_postal_code, cn.state_province AS cn_state_province,
            cn.account AS cn_account, cn.location AS cn_location,
            -- Invoice basic
            i.scac, i.inv_no, i.inv_date, i.payment_terms, i.cur,
            i.inv_amount, i.tt_charge,
            i.pickup_date, i.pickup_time, i.pod_date, i.pod_time, i.pod_name,
            i.gross_weight, i.gw_qualifier, i.gw_unit,
            i.bill_weight, i.bw_qualifier, i.bw_unit, i.bol,
            -- Charge
            c.description, c.rate, c.rate_qual, c.rated_currency,
            c.exchange_rate, c.expressed_currency, c.charge, c.weight,
            c.weight_qual, c.weight_type, c.sp_charge_code, c.sp_charge_desc,
            c.equipment_code, c.equipment_type, c.total_weight, c.total_weight_qual, c.service_code,
            c.volume, c.volume_qual, c.rated_quantity, c.rated_package_type,
            c.billed_quantity, c.billed_qualifier,
            c.length, c.width, c.height, c.measurement_unit,
            c.declared_value, c.commodity_class, c.commodity_code,
            c.correction_indicator, c.carriers_description, c.carriers_quantity,
            c.transport_service, c.origin_zone, c.destination_zone,
            -- Tax
            t.customer_reference, t.po, t.dn, t.rma, t.hawb, t.so,
            t.bill_of_lading_number, t.tracking_number, t.freight_bill_number,
            t.billing_account, t.bill_to_account, t.division_identifier,
            t.invoice_standard_code, t.carrier_name, t.business_unit,
            t.customer_vat_registration, t.carrier_vat_registration,
            t.carrier_tax_identity, t.sender_tax_identity, t.recipient_tax_identity,
            t.tax_bureau_name, t.tax_bureau_code
        FROM edi_210_invoice i
        LEFT JOIN edi_210_party bt ON bt.invoice_id = i.id AND bt.party_role = 'BILL_TO'
        LEFT JOIN edi_210_party bf ON bf.invoice_id = i.id AND bf.party_role = 'BILL_FROM'
        LEFT JOIN edi_210_party sh ON sh.invoice_id = i.id AND sh.party_role = 'SHIPPER'
        LEFT JOIN edi_210_party cn ON cn.invoice_id = i.id AND cn.party_role = 'CONSIGNEE'
        LEFT JOIN edi_210_charge c ON c.invoice_id = i.id
        LEFT JOIN edi_210_tax    t ON t.invoice_id = i.id
        <include refid="whereList"/>
        ORDER BY i.id, c.line_no
    </select>

</mapper>
