    <delete id="deleteByPrimaryKey">
        DELETE FROM edi_210_invoice WHERE id = #{id}
    </delete>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap">
        SELECT <include refid="invoiceColumns"/> FROM edi_210_invoice WHERE id = #{id}
    </select>

    <select id="selectIdByUk" resultType="java.lang.Long">
        SELECT id FROM edi_210_invoice
        WHERE region = #{region} AND scac = #{scac} AND inv_no = #{invNo}
        LIMIT 1
    </select>

    <update id="updateByPrimaryKeySelective" parameterType="com.boot.security.server.model.EDI210Invoice">
        UPDATE edi_210_invoice
        <set>
            <if test="region        != null">region = #{region},</if>
            <if test="scac          != null">scac = #{scac},</if>
            <if test="invNo         != null">inv_no = #{invNo},</if>
            <if test="invDate       != null">inv_date = #{invDate},</if>
            <if test="paymentTerms  != null">payment_terms = #{paymentTerms},</if>
            <if test="cur           != null">cur = #{cur},</if>
            <if test="invAmount     != null">inv_amount = #{invAmount},</if>
            <if test="ttCharge      != null">tt_charge = #{ttCharge},</if>
            <if test="pickupDate    != null">pickup_date = #{pickupDate},</if>
