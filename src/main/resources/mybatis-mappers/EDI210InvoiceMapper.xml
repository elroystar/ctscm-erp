            create_time,
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="region        != null">#{region},</if>
            <if test="scac          != null">#{scac},</if>
            <if test="invNo         != null">#{invNo},</if>
            <if test="invDate       != null">#{invDate},</if>
            <if test="paymentTerms  != null">#{paymentTerms},</if>
            <if test="cur           != null">#{cur},</if>
            <if test="invAmount     != null">#{invAmount},</if>
