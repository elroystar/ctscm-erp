            <if test="gwUnit        != null">gw_unit = #{gwUnit},</if>
            <if test="billWeight    != null">bill_weight = #{billWeight},</if>
            <if test="bwQualifier   != null">bw_qualifier = #{bwQualifier},</if>
            <if test="bwUnit        != null">bw_unit = #{bwUnit},</if>
            <if test="bol           != null">bol = #{bol},</if>
            <if test="status        != null">status = #{status},</if>
